{
  "expo": {
    "name": "Escarabajos Liga",
    "slug": "escarabajos-liga",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "escarabajos-liga",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a472a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.escarabajos.liga",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Usamos la cámara para actualizar tu foto de perfil.",
        "NSPhotoLibraryUsageDescription": "Accedemos a tus fotos para actualizar tu foto de perfil."
      },
      "entitlements": {
        "aps-environment": "production"
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a472a",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.escarabajos.liga"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#1a472a",
          "androidMode": "default",
          "androidCollapsedTitle": "Escarabajos Liga"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "escarabajos-liga"
      }
    },
    "privacyPolicyUrl": "https://escarabajos.nexosrv.one/api/privacy"
  }
}
